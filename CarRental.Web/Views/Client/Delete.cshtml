@model CarRental.Core.Models.Client

@{
    ViewData["Title"] = "Supprimer le Client";
}

@section Styles {
    <style>
        .warning-card {
            border-left: 5px solid #dc3545;
            border-radius: 8px;
        }

        .client-info-card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            background-color: #f8f9fa;
        }

        .info-row {
            padding: 8px 0;
            border-bottom: 1px solid #e9ecef;
        }

            .info-row:last-child {
                border-bottom: none;
            }

        .warning-icon {
            color: #dc3545;
            font-size: 4rem;
        }
    </style>
}

<div class="container mt-4">
    <!-- Bouton retour -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Carte d'avertissement -->
            <div class="card warning-card mb-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="me-4">
                            <i class="fas fa-exclamation-triangle warning-icon"></i>
                        </div>
                        <div>
                            <h3 class="card-title text-danger mb-3">
                                <i class="fas fa-trash-alt me-2"></i>Confirmation de suppression
                            </h3>
                            <p class="card-text lead">
                                Vous êtes sur le point de supprimer définitivement le client <strong>@Model.Nom @Model.Prenom</strong>.
                            </p>
                            <p class="card-text text-danger mb-0">
                                <i class="fas fa-exclamation-circle me-1"></i>
                                Cette action est irréversible et supprimera toutes les données associées à ce client.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Informations du client -->
            <div class="card client-info-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-user-circle me-2"></i>Informations du client à supprimer
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="info-row">
                                <strong class="me-2">CIN :</strong>
                                <span class="text-primary">@Model.CIN</span>
                            </div>
                            <div class="info-row">
                                <strong class="me-2">Nom complet :</strong>
                                @Model.Nom @Model.Prenom
                            </div>
                            <div class="info-row">
                                <strong class="me-2">Email :</strong>
                                <a href="mailto:@Model.Email" class="text-decoration-none">
                                    @Model.Email
                                </a>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-row">
                                <strong class="me-2">Téléphone :</strong>
                                <a href="tel:@Model.Telephone" class="text-decoration-none">
                                    @Model.Telephone
                                </a>
                            </div>
                            <div class="info-row">
                                <strong class="me-2">Ville :</strong>
                                <span class="badge bg-info">@Model.Ville</span>
                            </div>
                            <div class="info-row">
                                <strong class="me-2">Date d'inscription :</strong>
                                @Model.DateInscription.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>

                    <!-- Détails supplémentaires -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="alert alert-warning">
                                <div class="d-flex">
                                    <i class="fas fa-info-circle fa-2x me-3 align-self-start"></i>
                                    <div>
                                        <h6 class="alert-heading">Informations complémentaires</h6>
                                        <p class="mb-1">
                                            <strong>Adresse :</strong> @Model.Adresse
                                        </p>
                                        <p class="mb-1">
                                            <strong>Code postal :</strong> @Model.CodePostal
                                        </p>
                                        <p class="mb-1">
                                            <strong>Numéro de permis :</strong> @Model.NumeroPermis
                                        </p>
                                        <p class="mb-0">
                                            <strong>Date de naissance :</strong>
                                            @Model.DateNaissance.ToString("dd/MM/yyyy")
                                            @{
                                                var age = DateTime.Now.Year - Model.DateNaissance.Year;
                                                if (DateTime.Now < Model.DateNaissance.AddYears(age))
                                                {
                                                    age--;
                                                }
                                            }
                                            <span class="badge bg-secondary ms-2">@age ans</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Avertissement important -->
            <div class="alert alert-danger">
                <div class="d-flex align-items-center">
                    <i class="fas fa-ban fa-2x me-3"></i>
                    <div>
                        <h5 class="alert-heading">Attention !</h5>
                        <p class="mb-0">
                            Si ce client a des réservations en cours ou historiques, la suppression pourrait affecter
                            l'intégrité des données. Vérifiez qu'aucune réservation n'est associée à ce client avant de procéder.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Formulaire de suppression -->
            <div class="card">
                <div class="card-body">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="cin" value="@Model.CIN" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                                    <label class="form-check-label text-danger" for="confirmDelete">
                                        <strong>Je confirme vouloir supprimer ce client</strong>
                                    </label>
                                    <div class="form-text">
                                        Cochez cette case pour confirmer la suppression
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="confirmIrreversible">
                                    <label class="form-check-label text-danger" for="confirmIrreversible">
                                        <strong>Je comprends que cette action est irréversible</strong>
                                    </label>
                                    <div class="form-text">
                                        Cochez cette case pour confirmer votre compréhension
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <div>
                                <a asp-action="Details" asp-route-cin="@Model.CIN"
                                   class="btn btn-info">
                                    <i class="fas fa-eye me-2"></i>Voir les détails
                                </a>

                                <a asp-action="Edit" asp-route-cin="@Model.CIN"
                                   class="btn btn-warning ms-2">
                                    <i class="fas fa-edit me-2"></i>Modifier à la place
                                </a>
                            </div>

                            <div>
                                <a asp-action="Index" class="btn btn-secondary me-2">
                                    <i class="fas fa-times me-2"></i>Annuler
                                </a>

                                <button type="submit" class="btn btn-danger"
                                        id="deleteButton" disabled>
                                    <i class="fas fa-trash-alt me-2"></i>Supprimer définitivement
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Désactiver le bouton de suppression tant que les deux cases ne sont pas cochées
            function updateDeleteButton() {
                var confirmDelete = $('#confirmDelete').is(':checked');
                var confirmIrreversible = $('#confirmIrreversible').is(':checked');
                $('#deleteButton').prop('disabled', !(confirmDelete && confirmIrreversible));
            }

            $('#confirmDelete, #confirmIrreversible').on('change', function() {
                updateDeleteButton();
            });

            // Animation
            $('.card').css('opacity', '0').animate({ opacity: 1 }, 500);

            // Confirmation supplémentaire
            $('#deleteButton').on('click', function(e) {
                if (!confirm('Êtes-vous ABSOLUMENT sûr de vouloir supprimer ce client ?')) {
                    e.preventDefault();
                    return false;
                }
            });

            // Message d'avertissement au survol du bouton
            $('#deleteButton').hover(
                function() {
                    $(this).html('<i class="fas fa-exclamation-triangle me-2"></i>SUPPRIMER DÉFINITIVEMENT');
                    $(this).addClass('btn-lg');
                },
                function() {
                    $(this).html('<i class="fas fa-trash-alt me-2"></i>Supprimer définitivement');
                    $(this).removeClass('btn-lg');
                }
            );
        });
    </script>
}