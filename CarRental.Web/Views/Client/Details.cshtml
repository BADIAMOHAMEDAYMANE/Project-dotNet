@model CarRental.Core.Models.Client

@{
    ViewData["Title"] = "Détails du Client";
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .card-header {
            border-radius: 10px 10px 0 0 !important;
        }

        .info-label {
            font-weight: 600;
            color: #2c3e50;
        }

        .info-value {
            color: #34495e;
            padding-left: 10px;
        }

        .badge-age {
            font-size: 0.9em;
            padding: 5px 10px;
        }
    </style>
}

<div class="container mt-4">
    <!-- Bouton retour -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-user-circle me-2"></i>@ViewData["Title"]
                        </h4>
                        <div>
                            <span class="badge bg-light text-dark">
                                <i class="fas fa-calendar-alt me-1"></i>
                                Inscrit le @Model.DateInscription.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Informations principales -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5 class="border-bottom pb-2 mb-3">
                                <i class="fas fa-id-card me-2 text-primary"></i>Informations Personnelles
                            </h5>

                            <div class="row mb-2">
                                <div class="col-4 info-label">CIN :</div>
                                <div class="col-8 info-value">
                                    <strong class="text-primary">@Model.CIN</strong>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Nom :</div>
                                <div class="col-8 info-value">@Model.Nom</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Prénom :</div>
                                <div class="col-8 info-value">@Model.Prenom</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Date de naissance :</div>
                                <div class="col-8 info-value">
                                    @Model.DateNaissance.ToString("dd/MM/yyyy")
                                    @{
                                        var age = DateTime.Now.Year - Model.DateNaissance.Year;
                                        if (DateTime.Now < Model.DateNaissance.AddYears(age))
                                        {
                                            age--;
                                        }
                                    }
                                    <span class="badge @(age >= 18 ? "bg-success" : "bg-warning") badge-age ms-2">
                                        @age ans
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h5 class="border-bottom pb-2 mb-3">
                                <i class="fas fa-address-card me-2 text-primary"></i>Coordonnées
                            </h5>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Email :</div>
                                <div class="col-8 info-value">
                                    <a href="mailto:@Model.Email" class="text-decoration-none">
                                        <i class="fas fa-envelope me-1 text-primary"></i>@Model.Email
                                    </a>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Téléphone :</div>
                                <div class="col-8 info-value">
                                    <a href="tel:@Model.Telephone" class="text-decoration-none">
                                        <i class="fas fa-phone me-1 text-primary"></i>@Model.Telephone
                                    </a>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Adresse :</div>
                                <div class="col-8 info-value">@Model.Adresse</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Ville :</div>
                                <div class="col-8 info-value">
                                    <span class="badge bg-info">@Model.Ville</span>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-4 info-label">Code postal :</div>
                                <div class="col-8 info-value">@Model.CodePostal</div>
                            </div>
                        </div>
                    </div>

                    <!-- Informations permis -->
                    <div class="row">
                        <div class="col-12">
                            <h5 class="border-bottom pb-2 mb-3">
                                <i class="fas fa-car me-2 text-primary"></i>Informations Permis
                            </h5>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="info-label">Numéro de permis :</div>
                                    <div class="info-value">
                                        <code class="bg-light p-2 rounded d-inline-block">@Model.NumeroPermis</code>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="info-label">Date d'inscription :</div>
                                    <div class="info-value">
                                        <i class="fas fa-calendar-check me-1 text-success"></i>
                                        @Model.DateInscription.ToString("dd/MM/yyyy à HH:mm")
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="info-label">Ancienneté :</div>
                                    <div class="info-value">
                                        @{
                                            var inscriptionDays = (DateTime.Now - Model.DateInscription).Days;
                                            var years = inscriptionDays / 365;
                                            var months = (inscriptionDays % 365) / 30;
                                        }
                                        @if (years > 0)
                                        {
                                            <span class="badge bg-success">
                                                @years an@(years > 1 ? "s" : "")
                                                @(months > 0 ? $"{months} mois" : "")
                                            </span>
                                        }
                                        else if (months > 0)
                                        {
                                            <span class="badge bg-info">
                                                @months mois
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                Nouveau client
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="row mt-5">
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <a asp-action="Edit" asp-route-cin="@Model.CIN"
                                       class="btn btn-warning">
                                        <i class="fas fa-edit me-2"></i>Modifier
                                    </a>

                                    <a asp-action="Index" class="btn btn-secondary ms-2">
                                        <i class="fas fa-list me-2"></i>Liste clients
                                    </a>
                                </div>

                                <div>
                                    <button type="button" class="btn btn-danger"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal">
                                        <i class="fas fa-trash me-2"></i>Supprimer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de confirmation de suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirmation de suppression
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer le client <strong>@Model.Nom @Model.Prenom</strong> ?</p>
                <p class="text-danger">
                    <i class="fas fa-exclamation-circle me-1"></i>
                    Cette action est irréversible. Toutes les données du client seront perdues.
                </p>
                <div class="alert alert-warning mt-3">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Attention :</strong> Si ce client a des réservations en cours, vous ne pourrez pas le supprimer.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Annuler
                </button>
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="cin" value="@Model.CIN" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Supprimer définitivement
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Animation de la carte
            $('.card').css('opacity', '0').animate({ opacity: 1 }, 600);

            // Tooltips
            $('[title]').tooltip();

            // Confirmation avant suppression via modal
            $('#deleteModal').on('show.bs.modal', function (event) {
                // Optionnel : ajouter des effets
            });

            // Copier le numéro de permis au clic
            $('.code').on('click', function() {
                var text = $(this).text();
                navigator.clipboard.writeText(text).then(function() {
                    var original = $(this).html();
                    $(this).html('<i class="fas fa-check text-success me-1"></i>Copié !');
                    setTimeout(() => {
                        $(this).html(original);
                    }, 2000);
                }.bind(this));
            });
        });
    </script>
}