@model IEnumerable<CarRental.Core.Models.Client>

@{
    ViewData["Title"] = "Liste des Clients";
}

@section Styles {
    <style>
        .table th {
            background-color: #2c3e50;
            color: white;
        }

        .btn-group .btn {
            margin-right: 2px;
        }

            .btn-group .btn:last-child {
                margin-right: 0;
            }

        .table-hover tbody tr:hover {
            background-color: rgba(52, 152, 219, 0.1);
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 0, 0, 0.02);
        }

        .alert-warning a {
            color: #856404;
            text-decoration: underline;
            font-weight: bold;
        }

            .alert-warning a:hover {
                color: #533f03;
            }

        .error-message {
            animation: fadeIn 0.5s;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }
    </style>
}

<div class="container mt-4">
    <!-- Messages d'alerte -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show error-message" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-users me-2"></i>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-user-plus me-2"></i>Nouveau Client
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                <tr>
                    <th>CIN</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Ville</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.CIN</strong></td>
                        <td>@item.Nom</td>
                        <td>@item.Prenom</td>
                        <td>
                            <a href="mailto:@item.Email" class="text-decoration-none">
                                <i class="fas fa-envelope me-1"></i>@item.Email
                            </a>
                        </td>
                        <td>
                            <a href="tel:@item.Telephone" class="text-decoration-none">
                                <i class="fas fa-phone me-1"></i>@item.Telephone
                            </a>
                        </td>
                        <td>
                            <span class="badge bg-info">@item.Ville</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group" aria-label="Actions">
                                <a asp-action="Details" asp-route-cin="@item.CIN"
                                   class="btn btn-info btn-sm" title="Voir détails">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-cin="@item.CIN"
                                   class="btn btn-warning btn-sm" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-cin="@item.CIN"
                                   class="btn btn-danger btn-sm" title="Supprimer">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="mt-3 text-muted">
            <small>
                <i class="fas fa-info-circle me-1"></i>
                Total : @Model.Count() client(s) <!-- La vérification de null est déjà faite plus haut -->
            </small>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                <div>
                    <h5 class="alert-heading">Aucun client trouvé</h5>
                    <p class="mb-0">Commencez par ajouter votre premier client en cliquant sur le bouton ci-dessus.</p>
                    <p class="mb-0 mt-2">
                        <a asp-action="Create" class="btn btn-sm btn-warning">
                            <i class="fas fa-user-plus me-1"></i>Ajouter un client
                        </a>
                    </p>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-link">Déconnexion</button>
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </div>
    }
</div>



@section Scripts {
    <script>
        $(document).ready(function() {
            // Auto-dismiss des alertes après 5 secondes
            setTimeout(function() {
                $('.alert').alert('close');
            }, 5000);

            // Ajouter un effet de survol aux lignes du tableau
            $('.table tbody tr').hover(
                function() {
                    $(this).css('transform', 'translateY(-2px)');
                    $(this).css('box-shadow', '0 2px 5px rgba(0,0,0,0.1)');
                    $(this).css('transition', 'all 0.2s ease');
                },
                function() {
                    $(this).css('transform', 'translateY(0)');
                    $(this).css('box-shadow', 'none');
                }
            );

            // Confirmation avant suppression
            $('.btn-danger').on('click', function(e) {
                if (!confirm('Êtes-vous sûr de vouloir supprimer ce client ?')) {
                    e.preventDefault();
                }
            });

            // Tooltips pour les boutons d'actions
            $('[title]').tooltip({
                placement: 'top',
                trigger: 'hover'
            });

            // Animation de chargement
            $('.table').css('opacity', '0').animate({ opacity: 1 }, 500);
        });
    </script>
}