@model IEnumerable<CarRental.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Liste des Véhicules";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus-circle me-2"></i> Ajouter un Véhicule
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="card shadow">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Immatriculation</th>
                                <th>Marque</th>
                                <th>Modèle</th>
                                <th>Année</th>
                                <th>Catégorie</th>
                                <th>Kilométrage</th>
                                <th>Statut</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vehicule in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@vehicule.Immatriculation</td>
                                    <td>@vehicule.Marque</td>
                                    <td>@vehicule.Modele</td>
                                    <td>@(vehicule.Annee?.ToString() ?? "-")</td>
                                    <td>
                                        @if (vehicule.Categorie != null)
                                        {
                                            <span class="badge bg-secondary">@vehicule.Categorie.Nom</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@vehicule.Kilometrage.ToString("N0") km</td>
                                    <td>
                                        @if (vehicule.Statut == "Disponible")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle me-1"></i>@vehicule.Statut
                                            </span>
                                        }
                                        else if (vehicule.Statut == "Loué")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-car me-1"></i>@vehicule.Statut
                                            </span>
                                        }
                                        else if (vehicule.Statut == "En maintenance")
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-wrench me-1"></i>@vehicule.Statut
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times-circle me-1"></i>@vehicule.Statut
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@vehicule.Id"
                                               class="btn btn-sm btn-info"
                                               title="Détails">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@vehicule.Id"
                                               class="btn btn-sm btn-warning"
                                               title="Modifier">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@vehicule.Id"
                                               class="btn btn-sm btn-danger"
                                               title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <i class="fas fa-info-circle me-2"></i>
                Total: <strong>@Model.Count()</strong> véhicule(s)
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle me-2"></i>
            Aucun véhicule enregistré pour le moment.
            <a asp-action="Create" class="alert-link">Cliquez ici pour ajouter un véhicule</a>.
        </div>
    }
</div>

@section Styles {
    <style>
        .table-hover tbody tr:hover {
            background-color: #f8f9fa;
            cursor: pointer;
        }

        .btn-group .btn {
            margin: 0 2px;
        }

        .badge {
            font-size: 0.85rem;
            padding: 0.4em 0.6em;
        }

        .card {
            border: none;
            border-radius: 10px;
        }
    </style>
}