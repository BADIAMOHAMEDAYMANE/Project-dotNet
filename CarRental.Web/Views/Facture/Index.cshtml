@model IEnumerable<CarRental.Core.Models.Facture>

@{
    ViewData["Title"] = "Mes Factures";
}

<div class="factures-page">
    <!-- En-tęte avec design moderne -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="fas fa-file-invoice"></i>
            </div>
            <div>
                <h1 class="page-title">Mes Factures</h1>
                <p class="page-subtitle">Consultez et téléchargez vos factures de location</p>
            </div>
        </div>
        <div class="header-stats">
            <div class="stat-card">
                <i class="fas fa-receipt"></i>
                <div>
                    <span class="stat-number">@Model.Count()</span>
                    <span class="stat-label">Factures</span>
                </div>
            </div>
            <div class="stat-card">
                <i class="fas fa-money-bill-wave"></i>
                <div>
                    <span class="stat-number">@Model.Sum(f => f.MontantTotal).ToString("N2")</span>
                    <span class="stat-label">Total MAD</span>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <!-- État vide avec illustration -->
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-file-invoice"></i>
            </div>
            <h3>Aucune facture disponible</h3>
            <p>Vous n'avez pas encore de factures. Elles apparaîtront ici aprčs vos locations.</p>
            <a asp-controller="Client" asp-action="Dashboard" class="btn-primary-custom">
                <i class="fas fa-home me-2"></i>Retour au tableau de bord
            </a>
        </div>
    }
    else
    {
        <!-- Grille de factures -->
        <div class="factures-grid">
            @foreach (var facture in Model.OrderByDescending(f => f.DateFacture))
            {
                <div class="facture-card">
                    <!-- Badge de statut -->
                    <div class="facture-badge">
                        <span class="badge-paid">
                            <i class="fas fa-check-circle"></i> Payée
                        </span>
                    </div>

                    <!-- En-tęte de la carte -->
                    <div class="facture-header">
                        <div class="facture-number">
                            <i class="fas fa-hashtag"></i>
                            <span>@facture.Id</span>
                        </div>
                        <div class="facture-date">
                            <i class="far fa-calendar-alt"></i>
                            @facture.DateFacture.ToString("dd MMM yyyy")
                        </div>
                    </div>

                    <!-- Informations véhicule -->
                    <div class="facture-vehicle">
                        <div class="vehicle-icon">
                            <i class="fas fa-car"></i>
                        </div>
                        <div class="vehicle-info">
                            <h4>@facture.Location?.Vehicule?.Marque</h4>
                            <p>@facture.Location?.Vehicule?.Modele</p>
                        </div>
                    </div>

                    <!-- Période de location -->
                    <div class="facture-period">
                        <div class="period-item">
                            <i class="fas fa-calendar-check"></i>
                            <div>
                                <span class="period-label">Début</span>
                                <span class="period-date">@facture.Location?.DateDebut.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="period-divider">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                        <div class="period-item">
                            <i class="fas fa-calendar-times"></i>
                            <div>
                                <span class="period-label">Fin</span>
                                <span class="period-date">@facture.Location?.DateFin.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Montant -->
                    <div class="facture-amount">
                        <span class="amount-label">Montant total</span>
                        <span class="amount-value">@facture.MontantTotal.ToString("N2") <small>MAD</small></span>
                    </div>

                    <!-- Actions -->
                    <div class="facture-actions">
                        <a asp-action="Details" asp-route-id="@facture.Id" class="btn-view">
                            <i class="fas fa-eye"></i>
                            <span>Voir détails</span>
                        </a>
                        
                        @if (!string.IsNullOrEmpty(facture.CheminFichier))
                        {
                            <a asp-action="Download" asp-route-id="@facture.Id" class="btn-download">
                                <i class="fas fa-download"></i>
                                <span>@facture.Format</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Bouton retour -->
        <div class="page-footer">
            <a asp-controller="Client" asp-action="Dashboard" class="btn-back">
                <i class="fas fa-arrow-left me-2"></i>Retour au tableau de bord
            </a>
        </div>
    }
</div>

@section Styles {
<style>
    .factures-page {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem;
    }

    /* En-tęte de page */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 2.5rem;
        margin-bottom: 3rem;
        color: white;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .header-icon {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        margin: 0.5rem 0 0 0;
        opacity: 0.9;
        font-size: 1.1rem;
    }

    /* Statistiques */
    .header-stats {
        display: flex;
        gap: 1.5rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        padding: 1.2rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
    }

    .stat-card i {
        font-size: 1.8rem;
        opacity: 0.9;
    }

    .stat-number {
        display: block;
        font-size: 1.8rem;
        font-weight: 700;
        line-height: 1;
    }

    .stat-label {
        display: block;
        font-size: 0.9rem;
        opacity: 0.8;
        margin-top: 0.3rem;
    }

    /* Grille de factures */
    .factures-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    /* Carte de facture */
    .facture-card {
        background: white;
        border-radius: 20px;
        padding: 1.8rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .facture-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    }

    .facture-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    }

    /* Badge de statut */
    .facture-badge {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
    }

    .badge-paid {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* En-tęte de facture */
    .facture-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-right: 100px;
    }

    .facture-number {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.4rem;
        font-weight: 700;
        color: #2d3748;
    }

    .facture-number i {
        color: #667eea;
    }

    .facture-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #718096;
        font-size: 0.95rem;
    }

    /* Véhicule */
    .facture-vehicle {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #f7fafc;
        border-radius: 12px;
    }

    .vehicle-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .vehicle-info h4 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: #2d3748;
    }

    .vehicle-info p {
        margin: 0.2rem 0 0 0;
        color: #718096;
        font-size: 0.95rem;
    }

    /* Période */
    .facture-period {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #fff5f5;
        border-radius: 12px;
        border-left: 4px solid #fc8181;
    }

    .period-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex: 1;
    }

    .period-item i {
        color: #fc8181;
        font-size: 1.2rem;
    }

    .period-label {
        display: block;
        font-size: 0.75rem;
        color: #718096;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .period-date {
        display: block;
        font-size: 0.95rem;
        font-weight: 600;
        color: #2d3748;
        margin-top: 0.2rem;
    }

    .period-divider {
        color: #cbd5e0;
        padding: 0 0.5rem;
    }

    /* Montant */
    .facture-amount {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.2rem;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .amount-label {
        color: white;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .amount-value {
        color: white;
        font-size: 1.8rem;
        font-weight: 700;
    }

    .amount-value small {
        font-size: 1rem;
        opacity: 0.9;
    }

    /* Actions */
    .facture-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
    }

    .btn-view, .btn-download {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.8rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-view {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-view:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-download {
        background: #f7fafc;
        color: #2d3748;
        border: 2px solid #e2e8f0;
    }

    .btn-download:hover {
        background: #edf2f7;
        border-color: #cbd5e0;
        transform: translateY(-2px);
        color: #2d3748;
    }

    /* État vide */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .empty-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        font-size: 3rem;
        color: white;
    }

    .empty-state h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 1rem;
    }

    .empty-state p {
        color: #718096;
        font-size: 1.1rem;
        margin-bottom: 2rem;
    }

    /* Boutons */
    .btn-primary-custom, .btn-back {
        display: inline-flex;
        align-items: center;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-primary-custom:hover, .btn-back:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .page-footer {
        text-align: center;
        margin-top: 3rem;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .factures-page {
            padding: 1rem;
        }

        .page-header {
            padding: 1.5rem;
        }

        .header-content {
            flex-direction: column;
            text-align: center;
        }

        .page-title {
            font-size: 1.8rem;
        }

        .header-stats {
            flex-direction: column;
        }

        .factures-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .facture-period {
            flex-direction: column;
            gap: 1rem;
        }

        .period-divider {
            transform: rotate(90deg);
        }
    }
</style>
}