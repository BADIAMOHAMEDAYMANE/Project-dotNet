@model CarRental.Core.Models.Employee

@{
    ViewData["Title"] = "Mon Profil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .profile-container {
            padding: 2rem 0;
        }

        .profile-header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: white;
            margin: 0 auto 1.5rem;
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
        }

        .profile-name {
            text-align: center;
            font-size: 2rem;
            font-weight: 700;
            color: #2d3748;
            margin-bottom: 0.5rem;
        }

        .profile-role {
            text-align: center;
            color: #718096;
            font-size: 1.1rem;
            margin-bottom: 1rem;
        }

            .profile-role .badge {
                font-size: 1rem;
                padding: 0.5rem 1.5rem;
                border-radius: 20px;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            }

        .profile-card {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

            .profile-card h2 {
                color: #667eea;
                font-weight: 700;
                margin-bottom: 1.5rem;
                padding-bottom: 1rem;
                border-bottom: 3px solid #667eea;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .info-item {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 12px;
            border-left: 4px solid #667eea;
            transition: all 0.3s ease;
        }

            .info-item:hover {
                transform: translateX(5px);
                box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
            }

        .info-label {
            font-weight: 600;
            color: #667eea;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .info-value {
            font-size: 1.15rem;
            color: #2d3748;
            font-weight: 500;
        }

            .info-value.empty {
                color: #a0aec0;
                font-style: italic;
            }

        .btn-back {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

            .btn-back:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
                color: white;
            }

        .alert-info-custom {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 1rem 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

            .alert-info-custom i {
                font-size: 1.5rem;
            }

        .stats-mini-card {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            border-radius: 12px;
            padding: 1.5rem;
            text-align: center;
            transition: transform 0.3s ease;
        }

            .stats-mini-card:hover {
                transform: translateY(-5px);
            }

            .stats-mini-card i {
                font-size: 2rem;
                margin-bottom: 0.5rem;
            }

            .stats-mini-card h4 {
                font-size: 1.5rem;
                font-weight: 700;
                margin: 0.5rem 0;
            }

            .stats-mini-card p {
                margin: 0;
                opacity: 0.9;
            }
    </style>
}

<div class="profile-container">
    <div class="container">
        <!-- En-tête du profil -->
        <div class="profile-header">
            <a asp-controller="Admin" asp-action="Dashboard" class="btn-back">
                <i class="fas fa-arrow-left"></i>
                Retour au tableau de bord
            </a>

            <div class="profile-avatar">
                <i class="fas fa-user-tie"></i>
            </div>

            <h1 class="profile-name">@Model.Nom @Model.Prenom</h1>
            <p class="profile-role">
                <span class="badge">@Model.Role</span>
            </p>
            <p class="text-center text-muted">
                <i class="fas fa-envelope me-2"></i>@Model.Email
            </p>
        </div>

        <div class="row">
            <!-- Informations personnelles -->
            <div class="col-md-8">
                <div class="profile-card">
                    <h2>
                        <i class="fas fa-user-circle"></i>
                        Informations Personnelles
                    </h2>
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-id-badge"></i>
                                ID Employé
                            </div>
                            <div class="info-value">@Model.ID</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-user"></i>
                                Nom Complet
                            </div>
                            <div class="info-value">@Model.Nom @Model.Prenom</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-envelope"></i>
                                Adresse Email
                            </div>
                            <div class="info-value">@Model.Email</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-briefcase"></i>
                                Rôle / Fonction
                            </div>
                            <div class="info-value">
                                <span class="badge" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-size: 1rem; padding: 0.5rem 1rem;">
                                    @Model.Role
                                </span>
                            </div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-user-tag"></i>
                                Nom d'utilisateur
                            </div>
                            <div class="info-value">@Model.NomComplet</div>
                        </div>
                    </div>
                </div>

                <!-- Informations de contact -->
                <div class="profile-card">
                    <h2>
                        <i class="fas fa-address-book"></i>
                        Informations de Contact
                    </h2>
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-at"></i>
                                Email Principal
                            </div>
                            <div class="info-value">@Model.Email</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="fas fa-building"></i>
                                Département
                            </div>
                            <div class="info-value">
                                @if (Model.Role == "admin")
                                {
                                <span>Administration</span>
                                }
                                else
                                {
                                <span>@Model.Role</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Statistiques et actions -->
            <div class="col-md-4">
                <!-- Carte de statistiques -->
                <div class="profile-card">
                    <h2>
                        <i class="fas fa-chart-bar"></i>
                        Accès Rapides
                    </h2>
                    <div class="d-grid gap-3">
                        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-lg" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
                            <i class="fas fa-tachometer-alt me-2"></i>
                            Tableau de Bord
                        </a>

                        <a asp-controller="Client" asp-action="Index" class="btn btn-lg" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border: none;">
                            <i class="fas fa-users me-2"></i>
                            Gérer les Clients
                        </a>

                        <a asp-controller="Vehicule" asp-action="Index" class="btn btn-lg" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border: none;">
                            <i class="fas fa-car me-2"></i>
                            Gérer les Véhicules
                        </a>

                        <a asp-controller="Location" asp-action="Index" class="btn btn-lg" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); color: white; border: none;">
                            <i class="fas fa-clipboard-list me-2"></i>
                            Gérer les Locations
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Animation au survol des cartes d'information
            $('.info-item').hover(
                function () {
                    $(this).css('border-left-width', '6px');
                },
                function () {
                    $(this).css('border-left-width', '4px');
                }
            );

            // Log pour debug
            console.log('Admin Profile page loaded for:', '@Model.NomComplet');
        });
    </script>
}