<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarRental</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarRental.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @if (User.IsInRole("admin"))
                {
                    <!-- Logo redirige vers Dashboard Admin -->
                <a class="navbar-brand" asp-controller="Admin" asp-action="Dashboard">
                    <i class="fas fa-car me-2"></i>CarRental
                </a>
                }
                else if (User.IsInRole("Employe"))
                {
 <!-- Logo redirige vers Dashboard Employé -->
                <a class="navbar-brand" asp-controller="Employee" asp-action="Dashboard">
                    <i class="fas fa-car me-2"></i>CarRental
                </a>
                }
                else if (User.IsInRole("client"))
                {
 <!-- Logo redirige vers Dashboard Client -->
                <a class="navbar-brand" asp-controller="Client" asp-action="Dashboard">
                    <i class="fas fa-car me-2"></i>CarRental
                </a>
                }
                else
                {
 <!-- Logo redirige vers Home pour non-authentifiés -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-car me-2"></i>CarRental
                </a>
                }

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <!-- Accueil selon le rôle -->
                        @if (User.IsInRole("admin"))
                        {
                            <!-- Admin: Accueil = Dashboard Admin -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Admin" asp-action="Dashboard">
                                <i class="fas fa-home me-1"></i>Tableau de Bord
                            </a>
                        </li>
                        }
                        else if (User.IsInRole("Employe"))
                        {
 <!-- Employé: Accueil = Dashboard Employé -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Employee" asp-action="Dashboard">
                                <i class="fas fa-home me-1"></i>Tableau de Bord
                            </a>
                        </li>
                        }
                        else if (!User.Identity?.IsAuthenticated == true)
                        {
 <!-- Non-authentifié: Accueil = Home -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Accueil
                            </a>
                        </li>
                        }

                        <!-- Véhicules - Uniquement pour Admin et Employé -->
                        @if (User.IsInRole("admin") || User.IsInRole("Employe"))
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Vehicule" asp-action="Index">
                                <i class="fas fa-car me-1"></i>Véhicules
                            </a>
                        </li>
                        }

                       
                        @if (User.IsInRole("admin"))
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-shield me-1"></i>Administration
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Client" asp-action="Index">
                                        <i class="fas fa-users me-2"></i>Gestion Clients
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Location" asp-action="Index">
                                        <i class="fas fa-calendar-alt me-2"></i>Gestion Locations
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Vehicule" asp-action="Create">
                                        <i class="fas fa-plus-circle me-2"></i>Ajouter Véhicule
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Client" asp-action="Create">
                                        <i class="fas fa-user-plus me-2"></i>Ajouter Client
                                    </a>
                                </li>
                            </ul>
                        </li>
                        }

                        <!-- Menu Employé -->
                        @if (User.IsInRole("employe"))
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="employeeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-tie me-1"></i>Espace Employé
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="employeeDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Employee" asp-action="Dashboard">
                                        <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Employee" asp-action="Profile">
                                        <i class="fas fa-user-circle me-2"></i>Mon Profil
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Vehicule" asp-action="Index">
                                        <i class="fas fa-car me-2"></i>Véhicules
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Location" asp-action="Index">
                                        <i class="fas fa-calendar-alt me-2"></i>Locations
                                    </a>
                                </li>
                            </ul>
                        </li>
                        }

                        <!-- Menu Client - SIMPLIFIÉ -->
                        @if (User.IsInRole("client"))
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Client" asp-action="Dashboard">
                                <i class="fas fa-tachometer-alt me-1"></i>Mon Tableau de Bord
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Location" asp-action="CreerLocation">
                                <i class="fas fa-plus-circle me-1"></i>Nouvelle Demande
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Facture" asp-action="Index">
                                <i class="fas fa-file-invoice me-1"></i>Mes Factures
                            </a>
                        </li>
                        }
                    </ul>

                    <!-- Section droite avec informations utilisateur -->
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle me-1"></i>
                                @User.Identity.Name
                                <span class="badge bg-secondary ms-2">
                                    @{
                                            if (User.IsInRole("admin"))
                                            {
                                        <text>Admin</text>
                                            }
                                            else if (User.IsInRole("Employe"))
                                            {
                                        <text>Employé</text>
                                            }
                                            else if (User.IsInRole("client"))
                                            {
                                        <text>Client</text>
                                            }
                                    }
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <!-- Mon Profil - Pour tous les utilisateurs connectés -->
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user me-2"></i>Mon Profil
                                    </a>
                                </li>

                                <!-- Tableau de Bord selon le rôle -->
                                @if (User.IsInRole("admin"))
                                {
                                <li>
                                    <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                        <i class="fas fa-tachometer-alt me-2"></i>Tableau de Bord
                                    </a>
                                </li>
                                }
                                else if (User.IsInRole("Employe"))
                                {
                                <li>
                                    <a class="dropdown-item" asp-controller="Employee" asp-action="Dashboard">
                                        <i class="fas fa-tachometer-alt me-2"></i>Tableau de Bord
                                    </a>
                                </li>
                                }
                                else if (User.IsInRole("client"))
                                {
                                <li>
                                    <a class="dropdown-item" asp-controller="Client" asp-action="Dashboard">
                                        <i class="fas fa-tachometer-alt me-2"></i>Mon Tableau de Bord
                                    </a>
                                </li>
                                }

                                <li><hr class="dropdown-divider"></li>

                                <!-- Déconnexion -->
                                <li>
                                    @if (User.IsInRole("client"))
                                        {
                                    <form asp-controller="ClientAccount" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                                        </button>
                                    </form>
                                        }
                                        else
                                        {
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                                        </button>
                                    </form>
                                        }
                                </li>
                            </ul>
                        </li>
                        }
                        else
                        {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="ClientAccount" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Connexion
                            </a>
                        </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <!-- Messages de notification -->
            @if (TempData["Success"] != null)
            {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                <strong>Succès !</strong> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            }
            @if (TempData["Error"] != null)
            {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong>Erreur !</strong> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            }
            @if (TempData["Warning"] != null)
            {
            <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Attention !</strong> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            }
            @if (TempData["Info"] != null)
            {
            <div class="alert alert-info alert-dismissible fade show mt-3" role="alert">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Info :</strong> @TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            }

            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - CarRental - <a asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Auto-fermeture des alertes après 5 secondes -->
    <script>
        $(document).ready(function () {
            // Fermer automatiquement les alertes après 5 secondes
            setTimeout(function () {
                $('.alert').fadeOut('slow', function () {
                    $(this).alert('close');
                });
            }, 5000);
        });
    </script>
</body>
</html>